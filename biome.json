{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100,
    "trailingNewline": true
  },
  "javascript": {
    "formatter": {
      "semicolons": "always",
      "quoteStyle": "double",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "recommended": true,
        "noUselessUndefined": "off"
      },
      "correctness": {
        "recommended": true,
        "noNodejsModules": "off"
      },
      "performance": "error",
      "security": {
        "recommended": true,
        "noSecrets": "off"
      },
      "style": "error",
      "suspicious": {
        "recommended": true,
        "noTemplateCurlyInString": "off"
      },
      "a11y": "error",
      "nursery": {
        "recommended": true,
        "noTernary": "off"
      }
    }
  }
}
