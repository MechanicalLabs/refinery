{
  "name": "@mechlabs/refinery",
  "module": "dist/index.js",
  "version": "1.0.6",
  "type": "module",
  "private": false,
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MechanicalLabs/refinery.git"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "knip": "^6.15.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "bin": {
    "refinery": "./dist/index.js"
  },
  "scripts": {
    "format": "bun x @biomejs/biome format --write .",
    "lint": "bun x @biomejs/biome check --write .",
    "check:types": "bun x tsc",
    "check:deadcode": "bun x knip",
    "verify": "bun run lint && bun run check:types && bun run check:deadcode",
    "prepare": "sh install-hooks.sh",
    "check:types:watch": "bun x tsc --watch --preserveWatchOutput",
    "dev": "bun src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm",
    "build:binary": "bun build ./src/index.ts --compile --outfile dist/refinery"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "commander": "^15.0.0",
    "js-yaml": "^4.2.0",
    "picocolors": "^1.1.1",
    "ripthrow": "3.2.4",
    "smol-toml": "^1.6.1",
    "zod": "^4.4.3"
  }
}
