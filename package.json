{
  "name": "refinery",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "knip": "^6.12.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "scripts": {
    "format": "bun x @biomejs/biome format --write .",
    "lint": "bun x @biomejs/biome check --write .",
    "check:types": "bun x tsc",
    "check:deadcode": "bun x knip",
    "verify": "bun run lint && bun run check:types && bun run check:deadcode",
    "prepare": "sh install-hooks.sh",
    "check:types:watch": "bun x tsc --watch --preserveWatchOutput",
    "dev": "bun src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "build:binary": "bun build ./src/index.ts --compile --outfile dist/refinery"
  },
  "dependencies": {
    "picocolors": "^1.1.1"
  }
}
